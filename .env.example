# =============================================================================
# BACKEND API CONFIGURATION
# =============================================================================
# URL da API backend
# Desenvolvimento: http://localhost:3002/api/v1
# Produção: https://api.seu-dominio.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3002/api/v1

# =============================================================================
# ANALYTICS (OPCIONAL)
# =============================================================================
# Vercel Analytics - Set to true to enable analytics
NEXT_PUBLIC_VERCEL_ANALYTICS=false

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# URL base da aplicação frontend
# Desenvolvimento: http://localhost:3000
# Produção: https://seu-dominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# FEATURE FLAGS (OPCIONAL)
# =============================================================================
# Enable/disable features durante desenvolvimento
# NEXT_PUBLIC_ENABLE_COMMENTS=true
# NEXT_PUBLIC_ENABLE_REGISTRATIONS=true
# NEXT_PUBLIC_ENABLE_UPLOADS=true
